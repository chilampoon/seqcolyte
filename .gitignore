# Raw + simulated sequencing data (never committed)
data/
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# Barcode whitelists (large, license-restricted mirrors)
whitelists/

# Generated ground-truth labels (reproducible from config + control via `make sim`)
sim/labels/*.tsv

# Build/run logs
*.log

# Secrets
.env
.env.*

# Rust (qc-core compute core) — build artifacts only; src + Cargo.lock are committed
qc/core/target/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# OS
.DS_Store

# Third-party QC reference reports (full reports carry embedded assets + identifying run/sample
# metadata — never commit; redacted synthetic fixtures live under tests/fixtures/ instead)
data/example_reports/
wf-single-cell-report.html
