# Raw + simulated sequencing data (never committed)
data/
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# Barcode whitelists (large, license-restricted mirrors)
whitelists/

# Generated ground-truth labels (reproducible from config + control via `make sim`)
sim/labels/*.tsv

# Build/run logs
*.log

# Secrets
.env
.env.*

# Rust (seqcolyte-qc compute core) — build artifacts only; src + Cargo.lock are committed
rust/seqcolyte-qc/target/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# OS
.DS_Store
