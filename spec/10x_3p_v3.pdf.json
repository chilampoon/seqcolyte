  "library_generation": [
    {
      "step": 1,
      "title": "mRNA Capture & Reverse Transcription (GEM-RT)",
      "note": "Poly(dT) Gel Bead primer captures polyadenylated mRNA; RT produces barcoded, full-length first-strand cDNA carrying TruSeq Read 1, 16 bp 10x Barcode and 12 bp UMI inside GEMs."
    },
    {
      "step": 2,
      "title": "Template Switching & Transcript Extension",
      "note": "Template Switch Oligo (TSO, ...ACATGGG) primes template switching and adds the reverse-primer handle to the 3' end of cDNA."
    },
    {
      "step": 3,
      "title": "cDNA Amplification",
      "note": "Post GEM-RT cleanup, then PCR with cDNA Forward (Read 1) and Reverse (TSO) primers to generate barcoded full-length cDNA."
    },
    {
      "step": 4,
      "title": "Fragmentation, End Repair & A-tailing",
      "note": "Enzymatic fragmentation and size selection to optimize amplicon size."
    },
    {
      "step": 5,
      "title": "Adaptor Ligation",
      "note": "Ligate TruSeq forked adapter, adding the TruSeq Read 2 sequence."
    },
    {
      "step": 6,
      "title": "Sample Index PCR",
      "note": "PCR adds P5, P7 and the 8 bp i7 sample index (SI Primer + Chromium i7 Sample Index)."
    },
    {
      "step": 7,
      "title": "Final Library (Post Sample Index PCR size selection & QC)",
      "note": "Double-sided size selection yields the final P5...P7 paired-end library."
    }
  ],
