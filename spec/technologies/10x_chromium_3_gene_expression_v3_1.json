  "library_generation": [
    {
      "step": 1,
      "title": "GEM-RT: mRNA capture & reverse transcription",
      "summary": "Gel-bead poly(dT) primer captures poly(A) mRNA in each GEM and reverse transcription produces barcoded first-strand cDNA.",
      "note": "Inside each GEM the dissolved gel bead releases the poly(dT) primer (partial TruSeq Read 1 + 16 nt 10x barcode + 12 nt UMI + 30 nt oligo-dT VN), which anneals to the mRNA poly(A) tail; reverse transcriptase extends to make full-length first-strand cDNA carrying the barcode and UMI.",
      "product": "|--5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30VN[CDNA]------->\n                                                       3'- XXX...XXX(A)n mRNA -5'"
    },
    {
      "step": 2,
      "title": "Template switching",
      "summary": "Reverse transcriptase adds untemplated C's at the cDNA 3' end and switches onto the TSO, appending a fixed handle.",
      "note": "The TSO (AAGCAGTGGTATCAACGCAGAGTACAT + rGrGrG) base-pairs with the terminal C's; the RT copies the TSO, adding its reverse complement (CCCATGTACTCTGCGTTGATACCACTGCTT) to the 3' end of the first-strand cDNA.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30VN[CDNA]CCCATGTACTCTGCGTTGATACCACTGCTT -3'"
    },
    {
      "step": 3,
      "title": "Bulk cDNA amplification",
      "summary": "Pooled barcoded cDNA is PCR-amplified with the cDNA Forward and Reverse primers to generate double-stranded full-length cDNA.",
      "note": "After the emulsion is broken and cDNA purified on silane beads, PCR uses cDNA Forward primer (CTACACGACGCTCTTCCGATCT) and cDNA Reverse primer (AAGCAGTGGTATCAACGCAGAG) against the TSO handle to build mass for library construction.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30VN[CDNA]CCCATGTACTCTGCGTTGATACCACTGCTT -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12](A)30BN[CDNA]GGGTACATGAGACGCAACTATGGTGACGAA -5'"
    },
    {
      "step": 4,
      "title": "Fragmentation, End Repair & A-tailing",
      "summary": "Amplified cDNA is enzymatically fragmented, end-repaired, and A-tailed; only the barcode-bearing 5' fragment carries forward into the library.",
      "note": "Fragmentation optimizes amplicon size (~200-400 bp); end repair and A-tailing add a single 3' A overhang for adapter ligation. The 10x-barcode-containing fragment is the one that becomes a sequenceable library molecule.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30VN[CDNA]*A -3'\n3'-      A*GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12](A)30BN[CDNA] -5'"
    },
    {
      "step": 5,
      "title": "Adaptor Ligation",
      "summary": "The forked TruSeq Read 2 adapter is ligated to the A-tailed fragment ends.",
      "note": "Adaptor Oligos (double-stranded GATCGGAAGAGCACACGTCTGAACTCCAGTCAC / TCTAGCCTTCTCG) are ligated, adding the TruSeq Read 2 priming site to the cDNA-insert end of the molecule.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30VN[CDNA]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12](A)30BN[CDNA]TCTAGCCTTCTCG -5'"
    },
    {
      "step": 6,
      "title": "Sample Index PCR",
      "summary": "Dual-index PCR adds P5/i5 and P7/i7, completing the standard Illumina paired-end library.",
      "note": "Dual Index TT Set A i5 primer (P5 + i5 + partial TruSeq Read 1) and i7 primer (P7 + i7 + TruSeq Read 2) amplify the ligated fragment, producing the final construct flanked by P5 and P7.",
      "product": "5'- AATGATACGGCGACCACCGAGATCTACAC[SAMPLE_INDEX:10]ACACTCTTTCCCTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30VN[CDNA]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC[SAMPLE_INDEX:10]ATCTCGTATGCCGTCTTCTGCTTG -3'"
    }
  ],
