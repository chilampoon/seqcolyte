  "library_generation": [
    {
      "step": 1,
      "title": "GEM generation & barcoding (GEM-RT)",
      "summary": "Cells are partitioned with barcoded gel beads and lysed; poly-dT-primed reverse transcription with template switching builds 10x-barcoded, full-length first-strand cDNA.",
      "note": "Inside each GEM the gel bead dissolves, releasing the barcoded primer. Poly-dT RT Primer B anneals the mRNA poly(A) tail and reverse transcriptase (RT Enzyme E) synthesizes first-strand cDNA; on reaching the 5' cap it adds untemplated C's, the gel-bead TSO (\u2026GGG) base-pairs them, and RT switches template to copy the partial TruSeq Read 1, 16 nt 10x Barcode, and 12 nt UMI onto the cDNA 5' end.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12]TTTCTTATATGGG[CDNA](dT)[RT-handle] -3'"
    },
    {
      "step": 2,
      "title": "Post GEM-RT cleanup & cDNA amplification",
      "summary": "GEMs are broken, cDNA is silane-bead purified, and full-length barcoded cDNA is PCR-amplified with the cDNA Primers.",
      "note": "Dynabeads MyOne SILANE purify the barcoded first-strand cDNA. PCR with the cDNA Primers (against the partial TruSeq Read 1 and the RT-primer handle) generates double-stranded, full-length, 10x-barcoded cDNA for library construction.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12]TTTCTTATATGGG[CDNA](dT)[RT-handle] -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12]AAAGAATATACCC[CDNA](pA)[RT-handle] -5'"
    },
    {
      "step": 3,
      "title": "GEX fragmentation, end repair & A-tailing",
      "summary": "Amplified cDNA is enzymatically fragmented and A-tailed to optimize insert size for the 5' library.",
      "note": "Only a fixed 25% of the cDNA is carried forward. Enzymatic fragmentation, end repair, and A-tailing produce blunt, A-tailed fragments; the barcode-bearing 5' fragment retains partial Read 1 + barcode + UMI + TSO.",
      "product": "5'-  CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12]TTTCTTATATGGG[CDNA]*A -3'\n3'- A*GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12]AAAGAATATACCC[CDNA]   -5'"
    },
    {
      "step": 4,
      "title": "GEX adaptor ligation",
      "summary": "The TruSeq Read 2 adapter is ligated to the A-tailed fragment ends.",
      "note": "DNA Ligase attaches the Read 2 adapter, installing the Read 2 sequencing primer site at the fragment end contributed by the RT-primer handle.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12]TTTCTTATATGGG[CDNA]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12]AAAGAATATACCC[CDNA]TCTAGCCTTCTCGTGTGCAGACTTGAGGTCAGTG -5'"
    },
    {
      "step": 5,
      "title": "GEX Sample Index PCR",
      "summary": "PCR completes P5 + i5 onto the Read 1 side and adds i7 + P7 onto the Read 2 side, yielding the final dual-index Illumina library.",
      "note": "Library Amp Mix with a Dual Index TT Set A well extends the partial Read 1 to full P5/TruSeq Read 1 (adding the i5 index) and appends the i7 index and P7. Double-sided SPRIselect size-selects the final construct.",
      "product": "5'- AATGATACGGCGACCACCGAGATCTACAC[SAMPLE_INDEX:10]ACACTCTTTCCCTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12]TTTCTTATATGGG[CDNA]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC[SAMPLE_INDEX:10]ATCTCGTATGCCGTCTTCTGCTTG -3'\n3'- TTACTATGCCGCTGGTGGCTCTAGATGTG[SAMPLE_INDEX:10]TGTGAGAAAGGGATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12]AAAGAATATACCC[CDNA]TCTAGCCTTCTCGTGTGCAGACTTGAGGTCAGTG[SAMPLE_INDEX:10]TAGAGCATACGGCAGAAGACGAAC -5'"
    }
  ],
