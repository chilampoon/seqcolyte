  "library_generation": [
    {
      "step": 1,
      "title": "GEM-RT: mRNA capture, reverse transcription & template switch",
      "summary": "Poly(dT) RT primer primes polyadenylated mRNA and reverse transcriptase copies it, then template-switches onto the gel-bead oligo to append the 10x barcode and UMI at the transcript 5' end.",
      "note": "Inside each GEM the gel bead dissolves, releasing the barcoded Gel Bead Oligo (partial Read 1 + 16 nt 10x barcode + 10 nt UMI + rGrGrG TSO). MMLV-type reverse transcriptase extends the poly(dT) RT primer to the 5' cap, adds untemplated C's, and switches templates onto the bead TSO \u2014 producing barcoded full-length first-strand cDNA.",
      "product": "|--5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:10]TTTCTTATATGGG--------[CDNA]-------->NV(T)30 AAGCAGTGGTATCAACGCAGAGTAC -3'\n   3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:10]AAAGAATATACCC--------[CDNA]--------(A)nCATGAGACGCAACTATGGTGACGAA -5'"
    },
    {
      "step": 2,
      "title": "cDNA amplification (PCR)",
      "summary": "Barcoded full-length cDNA is PCR-amplified with forward (partial Read 1) and reverse (poly-dT handle) primers.",
      "note": "cDNA Forward Primer (CTACACGACGCTCTTCCGATCT) and cDNA Reverse Primer (AAGCAGTGGTATCAACGCAGAG) amplify against the common 5' and 3' ends added during GEM-RT, generating double-stranded full-length cDNA.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:10]TTTCTTATATGGG[CDNA]GTACTCTGCGTTGATACCACTGCTT -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:10]AAAGAATATACCC[CDNA]CATGAGACGCAACTATGGTGACGAA -5'"
    },
    {
      "step": 3,
      "title": "Fragmentation, End Repair & A-tailing",
      "summary": "Amplified cDNA is enzymatically fragmented and A-tailed to optimize amplicon size for library construction.",
      "note": "Enzymatic fragmentation gives variable-length fragments; end repair and A-tailing add a single 3' A overhang. Only the fragment retaining the 5' barcode/TSO end carries the cell barcode into the final library.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:10]TTTCTTATATGGG[CDNA]*A -3'\n         3'- A*[revcomp CDNA]AAAGAATATACCC[UMI:10][CELL_BARCODE:16]GATGTGCTGCGAGAAGGCTAGA -5'"
    },
    {
      "step": 4,
      "title": "Adaptor Ligation (Read 2)",
      "summary": "The TruSeq Read 2 adapter is ligated to the A-tailed cDNA fragments.",
      "note": "Adaptor Mix (PN-220026) ligates the forked Read 2 adapter onto the insert, adding the Read 2 primer site downstream of the cDNA.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:10]TTTCTTATATGGG[CDNA]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:10]AAAGAATATACCC[CDNA]TCTAGCCTTCTCG -5'"
    },
    {
      "step": 5,
      "title": "Sample Index PCR",
      "summary": "SI-PCR adds P5 and completes Read 1 on one end and adds the i7 sample index plus P7 on the other, yielding the final Illumina library.",
      "note": "SI-PCR forward primer appends P5 + partial Read 1; the Single Index Plate T Set A reverse primer appends the 8 nt i7 sample index + P7. The product is a standard Illumina paired-end construct spanning P5 to P7.",
      "product": "AATGATACGGCGACCACCGAGATCTACAC-TCTTTCCCTACACGACGCTCTTCCGATCT-[CELL_BARCODE:16]-[UMI:10]-TTTCTTATATGGG-[CDNA]-AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC-[SAMPLE_INDEX:8]-ATCTCGTATGCCGTCTTCTGCTTG"
    }
  ],
