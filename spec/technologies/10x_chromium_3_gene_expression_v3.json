  "library_generation": [
    {
      "step": 1,
      "title": "GEM formation & gel-bead dissolution",
      "summary": "Cells and barcoded gel beads are co-partitioned into GEMs, where the bead dissolves and releases barcoded poly(dT) primers.",
      "note": "On Chromium Chip B, single cells are combined at limiting dilution with Single Cell 3' v3 Gel Beads and Partitioning Oil. The gel bead dissolves and any co-partitioned cell is lysed, releasing the bead-attached primer.",
      "product": "|--5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30VN -3'"
    },
    {
      "step": 2,
      "title": "Reverse transcription (GEM-RT)",
      "summary": "Poly(dT) primes polyadenylated mRNA and reverse transcriptase makes first-strand cDNA.",
      "note": "53 C for 45 min. RT extends the barcoded oligo-dT along the mRNA; the MMLV-type RT adds a few untemplated C's at the cDNA 3' end.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30[CDNA]CCC------->\n                                               3'- (A)n[mRNA] -5'"
    },
    {
      "step": 3,
      "title": "Template switching",
      "summary": "TSO anneals to the untemplated C overhang and RT switches template, appending the TSO handle.",
      "note": "The TSO 3' rGrGrG pairs with the cDNA CCC overhang; RT copies the TSO, giving first-strand cDNA flanked by the Read 1 handle (5') and the TSO handle (3').",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30[CDNA]CCC------->\n                                                          3'- GGGTACATGAGACGCAACTATGGTGACGAA -5'\n\nFirst-strand product:\n5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30[CDNA]CCCATGTACTCTGCGTTGATACCACTGCTT -3'"
    },
    {
      "step": 4,
      "title": "Pooled cDNA amplification",
      "summary": "Emulsion is broken and pooled cDNA is PCR-amplified with the Forward (Read 1) and Reverse (TSO) primers.",
      "note": "98 C, 11-13 cycles. Generates double-stranded, full-length barcoded cDNA in bulk.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30[CDNA]CCCATGTACTCTGCGTTGATACCACTGCTT -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12](A)30[CDNA]GGGTACATGAGACGCAACTATGGTGACGAA -5'"
    },
    {
      "step": 5,
      "title": "Fragmentation, end repair & A-tailing",
      "summary": "Amplified cDNA is enzymatically fragmented and A-tailed to optimize insert size.",
      "note": "32 C fragmentation then 65 C end-repair/A-tailing; double-sided SPRI selects ~200-400 bp fragments. Only the Read 1-containing fragment carries the barcode/UMI.",
      "product": "  5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30[CDNA]*A -3'\n3'- A*GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12](A)30[CDNA] -5'"
    },
    {
      "step": 6,
      "title": "Adaptor ligation",
      "summary": "The TruSeq Read 2 adapter is ligated to the A-tailed fragment ends.",
      "note": "20 C for 15 min. Adds the partial TruSeq Read 2 handle used for the i7 index and Read 2.",
      "product": "5'- CTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30[CDNA]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -3'\n3'- GATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12](A)30[CDNA]TCTAGCCTTCTCG -5'"
    },
    {
      "step": 7,
      "title": "Sample Index PCR",
      "summary": "Library PCR adds P5, the i7 sample index, and P7 to make the final sequenceable library.",
      "note": "98 C, 6-16 cycles with the SI Primer (P5) and a Chromium i7 Sample Index primer (P7 + 8 bp index). Final library is flanked by P5 and P7 for Illumina bridge amplification.",
      "product": "5'- AATGATACGGCGACCACCGAGATCTACACTCTTTCCCTACACGACGCTCTTCCGATCT[CELL_BARCODE:16][UMI:12](T)30[CDNA]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC[SAMPLE_INDEX:8]ATCTCGTATGCCGTCTTCTGCTTG -3'\n3'- TTACTATGCCGCTGGTGGCTCTAGATGTGAGAAAGGGATGTGCTGCGAGAAGGCTAGA[CELL_BARCODE:16][UMI:12](A)30[CDNA]TCTAGCCTTCTCGTGTGCAGACTTGAGGTCAGTG[SAMPLE_INDEX:8]TAGAGCATACGGCAGAAGACGAAC -5'"
    }
  ],
