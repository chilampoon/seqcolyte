  "library_generation": [
    {
      "step": 1,
      "title": "Cell surface protein labeling",
      "summary": "Cells are stained with antibodies conjugated to a Feature Barcode oligonucleotide.",
      "note": "A TotalSeq-B antibody-oligonucleotide conjugate binds its cell-surface protein; the oligo carries a 15 bp feature barcode, a TruSeq Read 2 handle, and a 3' Capture Sequence 1 complement.",
      "product": "Antibody---5'-/5AmMC12/-GTGACTGGAGTTCAGACGTGTGCTCTTCCGATCT[SPACER:10][FEATURE_BARCODE:15][SPACER:9]GCTTTAAGGCCGGTCCTAGCAA-3'"
    },
    {
      "step": 2,
      "title": "GEM generation & gel-bead capture",
      "summary": "Inside a GEM the gel-bead Capture Sequence 1 primer hybridizes to the antibody feature-barcode oligo (and poly(dT) captures mRNA).",
      "note": "Cells are partitioned with barcoded gel beads; Capture Sequence 1 (TTGCTAGGACCGGCCTTAAAGC) anneals to the oligo's 3' end (GCTTTAAGGCCGGTCCTAGCAA).",
      "product": "|--5'- GTCAGATGTGTATAAGAGACAG[CELL_BARCODE:16][UMI:12]TTGCTAGGACCGGCCTTAAAGC------->\n                                                      ||||||||||||||||||||||\n    3'- AACGATCCTGGCCGGAATTTCG[SPACER:9][FEATURE_BARCODE:15][SPACER:10]TCTAGCCTTCTCGTGTGCAGACTTGAGGTCAGTG-/5AmMC12/-5'"
    },
    {
      "step": 3,
      "title": "Reverse-transcriptase extension (feature-barcode copy)",
      "summary": "The gel-bead primer is extended along the antibody oligo, copying the feature barcode into a barcoded product.",
      "note": "MMLV reverse transcriptase uses its DNA-dependent DNA polymerase activity to extend across the feature-barcode oligo, appending the 16 bp cell barcode and 12 bp UMI.",
      "product": "5'- GTCAGATGTGTATAAGAGACAG[CELL_BARCODE:16][UMI:12]TTGCTAGGACCGGCCTTAAAGC[SPACER:9][FEATURE_BARCODE:15][SPACER:10]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -3'"
    },
    {
      "step": 4,
      "title": "cDNA / feature-barcode amplification (Feature cDNA Primers 2)",
      "summary": "Pooled products are PCR-amplified after GEM breakage and silane cleanup.",
      "note": "Feature cDNA Primers 2 amplify both mRNA-derived cDNA and the feature-barcode DNA; feature forward primer GCAGCGTCAGATGTGTATAAGAGACAG and reverse primer GTGACTGGAGTTCAGACGT generate the double-stranded feature amplicon.",
      "product": "5'- GCAGCGTCAGATGTGTATAAGAGACAG[CELL_BARCODE:16][UMI:12]TTGCTAGGACCGGCCTTAAAGC[SPACER:9][FEATURE_BARCODE:15][SPACER:10]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -3'\n3'- CGTCGCAGTCTACACATATTCTCTGTC[CELL_BARCODE:16][UMI:12]AACGATCCTGGCCGGAATTTCG[SPACER:9][FEATURE_BARCODE:15][SPACER:10]TCTAGCCTTCTCGTGTGCAGACTTGAGGTCAGTG -5'"
    },
    {
      "step": 5,
      "title": "Size selection (SPRIselect)",
      "summary": "0.6X SPRIselect separates the short feature-barcode fraction (supernatant, ~180 bp) from full-length cDNA (pellet, >300 bp).",
      "note": "The transferred supernatant carries the feature-barcode DNA forward to Cell Surface Protein library construction; the pellet builds the 3' Gene Expression library.",
      "product": "5'- GCAGCGTCAGATGTGTATAAGAGACAG[CELL_BARCODE:16][UMI:12]TTGCTAGGACCGGCCTTAAAGC[SPACER:9][FEATURE_BARCODE:15][SPACER:10]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC -3'   (~180 bp feature-barcode fraction)"
    },
    {
      "step": 6,
      "title": "Sample Index PCR (Feature SI Primers 2 + Chromium i7)",
      "summary": "Feature SI Primers 2 add P5 + Nextera Read 1; the Chromium i7 primer adds the 8 bp sample index + P7 to yield the final Cell Surface Protein library.",
      "note": "Adds the P5/P7 flow-cell adapters and i7 sample index for Illumina bridge amplification; the final feature-barcode library is ~180 bp.",
      "product": "5'- AATGATACGGCGACCACCGAGATCTACACTCGTCGGCAGCGTCAGATGTGTATAAGAGACAG[CELL_BARCODE:16][UMI:12]TTGCTAGGACCGGCCTTAAAGC[SPACER:9][FEATURE_BARCODE:15][SPACER:10]AGATCGGAAGAGCACACGTCTGAACTCCAGTCAC[SAMPLE_INDEX:8]ATCTCGTATGCCGTCTTCTGCTTG -3'"
    }
  ],
  "library_sequencing": [
    {
      "read": "Read 1",
      "primer": "Nextera Read 1 / Read 1N: 5'-TCGTCGGCAGCGTCAGATGTGTATAAGAGACAG-3'",
      "template": "bottom",
      "cycles": 28,
      "note": "Read 1N primer anneals to the bottom strand and is extended 5'->3' (rightward), reading out the 16 bp 10x cell barcode + 12 bp UMI (top-strand identities).",
      "diagram": "                 5'-TCGTCGGCAGCGTCAGATGTGTATAAGAGACAG-------------------------->  (reads 16 bp CBC + 12 bp UMI)\n5'-...GAGATCTACACTCGTCGGCAGCGTCAGATGTGTATAAGAGACAGNNNNNNNNNNNNNNNNNNNNNNNNNNNNTTGCTAGGACCGGCCTTAAAGC...-3'\n3'-...CTCTAGATGTGAGCAGCCGTCGCAGTCTACACATATTCTCTGTCNNNNNNNNNNNNNNNNNNNNNNNNNNNNAACGATCCTGGCCGGAATTTCG...-5'\n                                                 |----16 bp cell barcode----||---12 bp UMI---|"
